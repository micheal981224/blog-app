<%- include('partials/header', { title: 'New Post' }) %>

<div class="page-form">

  <div class="form-header">
    <a href="/" class="back-link">← Back</a>
    <h1 class="form-title">New Post</h1>
    <p class="form-subtitle">Write something worth keeping.</p>
  </div>

  <% if (error) { %>
    <div class="form-error"><%= error %></div>
  <% } %>

  <form class="post-form" action="/posts" method="POST">

    <div class="form-row form-row--half">
      <div class="field">
        <label class="field-label" for="author">Author</label>
        <input
          class="field-input"
          type="text"
          id="author"
          name="author"
          placeholder="Your name"
          maxlength="80"
        />
      </div>
      <div class="field">
        <label class="field-label" for="tag">Tag</label>
        <input
          class="field-input"
          type="text"
          id="tag"
          name="tag"
          placeholder="e.g. Essay, Note, Idea"
          maxlength="40"
        />
      </div>
    </div>

    <div class="field">
      <label class="field-label" for="title">Title <span class="required">*</span></label>
      <input
        class="field-input field-input--title"
        type="text"
        id="title"
        name="title"
        placeholder="An unforgettable headline"
        maxlength="200"
        required
        autofocus
      />
    </div>

    <div class="field">
      <label class="field-label" for="content">Content <span class="required">*</span></label>
      <textarea
        class="field-textarea"
        id="content"
        name="content"
        placeholder="Write your post here. Separate paragraphs with a blank line."
        rows="18"
        required
      ></textarea>
      <div class="field-hint">Separate paragraphs with a blank line.</div>
    </div>

    <div class="form-actions">
      <a href="/" class="btn-ghost">Cancel</a>
      <button type="submit" class="btn-primary">Publish Post</button>
    </div>

  </form>

</div>

<%- include('partials/footer') %>
