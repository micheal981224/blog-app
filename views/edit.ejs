<%- include('partials/header', { title: 'Edit Post' }) %>

<div class="page-form">

  <div class="form-header">
    <a href="/posts/<%= post.id %>" class="back-link">← Back to post</a>
    <h1 class="form-title">Edit Post</h1>
    <p class="form-subtitle">Revise and refine.</p>
  </div>

  <% if (error) { %>
    <div class="form-error"><%= error %></div>
  <% } %>

  <form class="post-form" action="/posts/<%= post.id %>/edit" method="POST">

    <div class="form-row form-row--half">
      <div class="field">
        <label class="field-label" for="author">Author</label>
        <input
          class="field-input"
          type="text"
          id="author"
          name="author"
          value="<%= post.author %>"
          maxlength="80"
        />
      </div>
      <div class="field">
        <label class="field-label" for="tag">Tag</label>
        <input
          class="field-input"
          type="text"
          id="tag"
          name="tag"
          value="<%= post.tag %>"
          maxlength="40"
        />
      </div>
    </div>

    <div class="field">
      <label class="field-label" for="title">Title <span class="required">*</span></label>
      <input
        class="field-input field-input--title"
        type="text"
        id="title"
        name="title"
        value="<%= post.title %>"
        maxlength="200"
        required
        autofocus
      />
    </div>

    <div class="field">
      <label class="field-label" for="content">Content <span class="required">*</span></label>
      <textarea
        class="field-textarea"
        id="content"
        name="content"
        rows="18"
        required
      ><%= post.content %></textarea>
      <div class="field-hint">Separate paragraphs with a blank line.</div>
    </div>

    <div class="form-actions">
      <a href="/posts/<%= post.id %>" class="btn-ghost">Cancel</a>
      <button type="submit" class="btn-primary">Save Changes</button>
    </div>

  </form>

</div>

<%- include('partials/footer') %>
